// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Scope: Phase 1-3 data (Team, Player, DayDefault, DateOverride, Venue, Session, Rsvp).
// Do NOT add NextAuth models here - those are gated on Phase 5's auth trigger. See AGENTS.md.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Status {
  ANYTIME
  SPECIFIC
  UNAVAILABLE
}

model Team {
  id       String    @id @default(cuid())
  slug     String    @unique // shareable URL, e.g. "uncrowned-kings"
  name     String
  players  Player[]
  sessions Session[]
}

model Player {
  id        String         @id @default(cuid())
  teamId    String
  team      Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)
  name      String
  number    Int? // jersey number, nullable - 0 is a valid value
  defaults  DayDefault[]
  overrides DateOverride[]
  rsvps     Rsvp[]

  @@index([teamId])
}

model DayDefault {
  id        String   @id @default(cuid())
  playerId  String
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  dayOfWeek Int // 0=Sun ... 6=Sat
  status    Status   @default(UNAVAILABLE)
  fromTime  String? // "18:00", only set when status = SPECIFIC
  toTime    String?
  note      String? // e.g. "church," "work until 4:30"

  @@unique([playerId, dayOfWeek])
}

model DateOverride {
  id       String   @id @default(cuid())
  playerId String
  player   Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  date     DateTime // specific calendar date, not a day-of-week
  status   Status
  fromTime String?
  toTime   String?
  note     String?

  @@unique([playerId, date])
}

// ─── Phase 3: Sessions & Venues ───────────────────────────────────────────────

enum VenueType {
  RENTED_GYM // booked and paid, exclusive access, worth it only above minPlayers
  OPEN_GYM   // public gym time, no booking
  PARK       // free, no booking
}

model Venue {
  id             String    @id @default(cuid())
  name           String
  type           VenueType
  address        String?
  bookingUrl     String?
  costPerSession Int?      // cents — typical/last-used cost, RENTED_GYM only
  sessions       Session[]
}

model Session {
  id           String   @id @default(cuid())
  teamId       String
  team         Team     @relation(fields: [teamId], references: [id])
  venueId      String?
  venue        Venue?   @relation(fields: [venueId], references: [id])
  proposedById String?  // playerId of the player who proposed — null for legacy rows
  date         DateTime
  fromTime     String
  toTime       String
  costTotal    Int?     // cents — RENTED_GYM only, null for OPEN_GYM / PARK
  minPlayers   Int?     // RENTED_GYM only — editable, never hardcoded
  rsvps        Rsvp[]

  @@index([teamId])
}

model Rsvp {
  id        String   @id @default(cuid())
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  playerId  String
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  status    Status

  @@unique([sessionId, playerId])
}
