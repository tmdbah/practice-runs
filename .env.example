# Neon pooled connection string (hostname contains "-pooler").
# Used by the app's runtime Prisma Client (src/lib/prisma.ts).
DATABASE_URL="postgresql://user:password@ep-example-pooler.region.aws.neon.tech/practice_runs?sslmode=require"

# Neon direct (unpooled) connection string.
# Used only by the Prisma CLI (migrate/db push) via prisma.config.ts.
DIRECT_URL="postgresql://user:password@ep-example.region.aws.neon.tech/practice_runs?sslmode=require"
